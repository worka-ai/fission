{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Fission Design System tokens. Mirrors the Material Design 3 token architecture used by Fission's own `fission-theme` crate. Primitive tokens (color.*, spacing.*, typography.*, radius.*, elevation.*) cascade into semantic and component tokens.",
  "$meta": {
    "name": "Fission Design System",
    "version": "0.1.0",
    "framework": "fission (worka-ai/fission)",
    "license": "MIT"
  },

  "color": {
    "$description": "Primitive color tokens. The Fission palette has two parallel families: the teal *interactive* palette (from the docs site) and the orange/blue *signal* palette (from the logo). Slate is the neutral ramp.",

    "brand": {
      "orange": {
        "$description": "Logo nucleus / signal accent / energy.",
        "50":  { "value": "#FEF6EE", "type": "color" },
        "100": { "value": "#FDE8D2", "type": "color" },
        "200": { "value": "#FACBA0", "type": "color" },
        "300": { "value": "#F6A86A", "type": "color" },
        "400": { "value": "#F2904A", "type": "color" },
        "500": { "value": "#F08820", "type": "color", "$extensions": {"role": "brand-accent"} },
        "600": { "value": "#D8741A", "type": "color" },
        "700": { "value": "#A85916", "type": "color" },
        "800": { "value": "#7A3F10", "type": "color" },
        "900": { "value": "#4A2609", "type": "color" }
      },
      "blue": {
        "$description": "Logo orbit / signal accent / structure.",
        "50":  { "value": "#EEF6FD", "type": "color" },
        "100": { "value": "#D5E8F8", "type": "color" },
        "200": { "value": "#A8D0F2", "type": "color" },
        "300": { "value": "#7AB7EB", "type": "color" },
        "400": { "value": "#4DA6E0", "type": "color", "$extensions": {"role": "brand-accent"} },
        "500": { "value": "#2D8FCB", "type": "color" },
        "600": { "value": "#1F76AB", "type": "color" },
        "700": { "value": "#175C85", "type": "color" },
        "800": { "value": "#0F3F5C", "type": "color" },
        "900": { "value": "#082336", "type": "color" }
      }
    },

    "teal": {
      "$description": "Interactive palette (links, primary buttons, focus rings). Lifted from website/src/css/custom.css.",
      "50":  { "value": "#F0FDFA", "type": "color" },
      "100": { "value": "#CCFBF1", "type": "color" },
      "200": { "value": "#99F6E4", "type": "color" },
      "300": { "value": "#5EEAD4", "type": "color" },
      "400": { "value": "#2DD4BF", "type": "color", "$extensions": {"role": "primary-dark"} },
      "500": { "value": "#14B8A6", "type": "color" },
      "600": { "value": "#0D9488", "type": "color" },
      "700": { "value": "#0F766E", "type": "color", "$extensions": {"role": "primary-light"} },
      "800": { "value": "#115E59", "type": "color" },
      "900": { "value": "#134E4A", "type": "color" }
    },

    "slate": {
      "$description": "Neutral ramp. Matches Tailwind slate so direct Tailwind use stays on-brand.",
      "0":    { "value": "#FFFFFF", "type": "color" },
      "50":   { "value": "#F8FAFC", "type": "color" },
      "100":  { "value": "#F1F5F9", "type": "color" },
      "200":  { "value": "#E2E8F0", "type": "color" },
      "300":  { "value": "#CBD5E1", "type": "color" },
      "400":  { "value": "#94A3B8", "type": "color" },
      "500":  { "value": "#64748B", "type": "color" },
      "600":  { "value": "#475569", "type": "color" },
      "700":  { "value": "#334155", "type": "color" },
      "800":  { "value": "#1E293B", "type": "color" },
      "900":  { "value": "#0F172A", "type": "color" },
      "950":  { "value": "#020617", "type": "color" }
    },

    "semantic": {
      "success": { "value": "#10B981", "type": "color" },
      "warning": { "value": "#F59E0B", "type": "color" },
      "error":   { "value": "#E11D48", "type": "color" },
      "info":    { "value": "#0EA5E9", "type": "color" }
    },

    "light": {
      "$description": "Light theme — semantic surface tokens. Mirrors `Theme::default()` in fission-theme/src/lib.rs but rebound to the teal interactive palette used by the docs site.",
      "primary":         { "value": "{color.teal.700}", "type": "color" },
      "on_primary":      { "value": "{color.slate.0}",  "type": "color" },
      "primary_hover":   { "value": "{color.teal.800}", "type": "color" },
      "primary_subtle":  { "value": "{color.teal.50}",  "type": "color" },
      "secondary":       { "value": "{color.slate.700}", "type": "color" },
      "on_secondary":    { "value": "{color.slate.0}",  "type": "color" },
      "surface":         { "value": "{color.slate.0}",  "type": "color" },
      "surface_raised":  { "value": "{color.slate.0}",  "type": "color" },
      "surface_sunken":  { "value": "{color.slate.50}", "type": "color" },
      "background":      { "value": "{color.slate.0}",  "type": "color" },
      "border":          { "value": "{color.slate.200}", "type": "color" },
      "border_strong":   { "value": "{color.slate.300}", "type": "color" },
      "divider":         { "value": "{color.slate.200}", "type": "color" },
      "text_primary":    { "value": "{color.slate.900}", "type": "color" },
      "text_secondary":  { "value": "{color.slate.700}", "type": "color" },
      "text_muted":      { "value": "{color.slate.500}", "type": "color" },
      "text_link":       { "value": "{color.teal.700}", "type": "color" },
      "heading":         { "value": "{color.slate.900}", "type": "color" },
      "focus_ring":      { "value": "{color.teal.500}", "type": "color" },
      "error":           { "value": "{color.semantic.error}", "type": "color" },
      "success":         { "value": "{color.semantic.success}", "type": "color" },
      "warning":         { "value": "{color.semantic.warning}", "type": "color" },
      "info":            { "value": "{color.semantic.info}", "type": "color" }
    },

    "dark": {
      "$description": "Dark theme — semantic surface tokens. Mirrors `Theme::dark()` rebound to the docs-site dark palette.",
      "primary":         { "value": "{color.teal.400}", "type": "color" },
      "on_primary":      { "value": "#05211A",          "type": "color" },
      "primary_hover":   { "value": "{color.teal.300}", "type": "color" },
      "primary_subtle":  { "value": "{color.teal.900}", "type": "color" },
      "secondary":       { "value": "{color.slate.300}", "type": "color" },
      "on_secondary":    { "value": "{color.slate.950}", "type": "color" },
      "surface":         { "value": "{color.slate.900}", "type": "color" },
      "surface_raised":  { "value": "#0B1220",           "type": "color" },
      "surface_sunken":  { "value": "{color.slate.950}", "type": "color" },
      "background":      { "value": "{color.slate.950}", "type": "color" },
      "border":          { "value": "{color.slate.800}", "type": "color" },
      "border_strong":   { "value": "{color.slate.700}", "type": "color" },
      "divider":         { "value": "{color.slate.800}", "type": "color" },
      "text_primary":    { "value": "{color.slate.50}",  "type": "color" },
      "text_secondary":  { "value": "{color.slate.300}", "type": "color" },
      "text_muted":      { "value": "{color.slate.500}", "type": "color" },
      "text_link":       { "value": "#6EE7B7",           "type": "color" },
      "heading":         { "value": "{color.slate.50}",  "type": "color" },
      "focus_ring":      { "value": "{color.teal.300}", "type": "color" },
      "error":           { "value": "{color.semantic.error}", "type": "color" },
      "success":         { "value": "{color.semantic.success}", "type": "color" },
      "warning":         { "value": "{color.semantic.warning}", "type": "color" },
      "info":            { "value": "{color.semantic.info}", "type": "color" }
    },

    "material_baseline": {
      "$description": "The literal `Theme::default()` palette shipped by fission-theme/src/lib.rs (Material 3 baseline with purple primary). Recorded for completeness; the Fission *brand* uses teal instead — see color.light.*.",
      "primary":   { "value": "#67558F", "type": "color" },
      "secondary": { "value": "#625B71", "type": "color" },
      "error":     { "value": "#B3261E", "type": "color" }
    }
  },

  "typography": {
    "$description": "Type scale. Sizes match the Fission TypographyTokens (label_large 15, body_large 17, heading 28) extended with marketing display sizes from the docs site.",

    "font_family": {
      "sans":    { "value": "\"Inter\", \"Avenir Next\", \"Segoe UI\", Arial, sans-serif", "type": "fontFamily" },
      "serif":   { "value": "\"Iowan Old Style\", \"Palatino Linotype\", \"Book Antiqua\", Georgia, serif", "type": "fontFamily" },
      "mono":    { "value": "\"SFMono-Regular\", Menlo, Monaco, Consolas, \"Liberation Mono\", \"Courier New\", monospace", "type": "fontFamily" }
    },

    "font_weight": {
      "regular":  { "value": "400", "type": "fontWeight" },
      "medium":   { "value": "500", "type": "fontWeight" },
      "semibold": { "value": "600", "type": "fontWeight" },
      "bold":     { "value": "700", "type": "fontWeight" }
    },

    "font_size": {
      "xs":   { "value": "12px", "type": "dimension" },
      "sm":   { "value": "13px", "type": "dimension" },
      "base": { "value": "14px", "type": "dimension" },
      "label_large": { "value": "15px", "type": "dimension", "$description": "Maps to TypographyTokens.label_large_size in fission-theme." },
      "body": { "value": "15px", "type": "dimension", "$description": "Maps to TypographyTokens.body_medium_size." },
      "body_large": { "value": "17px", "type": "dimension", "$description": "Maps to TypographyTokens.body_large_size." },
      "lg":   { "value": "20px", "type": "dimension" },
      "xl":   { "value": "24px", "type": "dimension" },
      "h3":   { "value": "28px", "type": "dimension", "$description": "Maps to TypographyTokens.heading_size." },
      "h2":   { "value": "36px", "type": "dimension" },
      "h1":   { "value": "48px", "type": "dimension" },
      "display_sm": { "value": "60px", "type": "dimension" },
      "display_md": { "value": "72px", "type": "dimension" }
    },

    "line_height": {
      "display": { "value": "0.98", "type": "number" },
      "heading": { "value": "1.05", "type": "number" },
      "snug":    { "value": "1.4",  "type": "number" },
      "normal":  { "value": "1.6",  "type": "number" },
      "relaxed": { "value": "1.68", "type": "number" }
    },

    "letter_spacing": {
      "tight":  { "value": "-0.01em", "type": "dimension" },
      "normal": { "value": "0",       "type": "dimension" },
      "label":  { "value": "0.1em",   "type": "dimension" },
      "kicker": { "value": "0.14em",  "type": "dimension" }
    }
  },

  "spacing": {
    "$description": "Six-step scale from fission-theme SpacingTokens (none/xs/s/m/l/xl) plus marketing extensions.",
    "none": { "value": "0px",  "type": "dimension" },
    "xs":   { "value": "4px",  "type": "dimension" },
    "s":    { "value": "8px",  "type": "dimension" },
    "m":    { "value": "16px", "type": "dimension" },
    "l":    { "value": "24px", "type": "dimension" },
    "xl":   { "value": "32px", "type": "dimension" },
    "2xl":  { "value": "48px", "type": "dimension" },
    "3xl":  { "value": "64px", "type": "dimension" },
    "4xl":  { "value": "96px", "type": "dimension" }
  },

  "radius": {
    "$description": "Four steps from fission-theme RadiusTokens, plus marketing extensions for hero cards.",
    "none":   { "value": "0px",     "type": "dimension" },
    "small":  { "value": "4px",     "type": "dimension" },
    "medium": { "value": "8px",     "type": "dimension" },
    "large":  { "value": "12px",    "type": "dimension" },
    "xl":     { "value": "16px",    "type": "dimension" },
    "2xl":    { "value": "24px",    "type": "dimension" },
    "full":   { "value": "9999px",  "type": "dimension" }
  },

  "elevation": {
    "$description": "Six levels from fission-theme ElevationTokens. level0/level4/level5 are None in Rust; level4 is repurposed for marketing card hover, level5 for slide-deck cards.",
    "level0": { "value": "none", "type": "shadow" },
    "level1": { "value": "0 1px 2px 0 rgba(10, 13, 18, 0.05), 0 1px 3px 0 rgba(10, 13, 18, 0.1)", "type": "shadow" },
    "level2": { "value": "0 2px 4px -1px rgba(10, 13, 18, 0.06), 0 4px 6px -1px rgba(10, 13, 18, 0.1)", "type": "shadow" },
    "level3": { "value": "0 4px 8px -2px rgba(10, 13, 18, 0.1), 0 12px 24px -4px rgba(10, 13, 18, 0.12)",  "type": "shadow" },
    "level4": { "value": "0 18px 45px rgba(15, 23, 42, 0.14)", "type": "shadow" },
    "level5": { "value": "0 32px 80px rgba(15, 23, 42, 0.2)", "type": "shadow" },
    "focus":  { "value": "0 0 0 4px rgba(20, 184, 166, 0.32)", "type": "shadow" }
  },

  "motion": {
    "duration": {
      "instant": { "value": "0ms",   "type": "duration" },
      "micro":   { "value": "120ms", "type": "duration" },
      "fast":    { "value": "160ms", "type": "duration", "$description": "Default. Used for hover/press/focus on links and buttons." },
      "normal":  { "value": "200ms", "type": "duration" },
      "slow":    { "value": "300ms", "type": "duration" },
      "deliberate": { "value": "480ms", "type": "duration" }
    },
    "easing": {
      "linear":     { "value": "linear", "type": "cubicBezier" },
      "standard":   { "value": "cubic-bezier(0.16, 0.84, 0.32, 1)", "type": "cubicBezier", "$description": "Soft ease-out — default for almost everything." },
      "in":         { "value": "cubic-bezier(0.4, 0, 1, 1)", "type": "cubicBezier" },
      "out":        { "value": "cubic-bezier(0, 0, 0.2, 1)", "type": "cubicBezier" },
      "ease":       { "value": "ease", "type": "cubicBezier" }
    }
  },

  "component": {
    "$description": "Component-level token bindings. Mirrors the ComponentTheme structs in fission-theme/src/lib.rs.",

    "button": {
      "height":             { "value": "42px",          "type": "dimension" },
      "padding_horizontal": { "value": "{spacing.m}",   "type": "dimension" },
      "padding_vertical":   { "value": "{spacing.s}",   "type": "dimension" },
      "radius":             { "value": "{radius.full}", "type": "dimension" },
      "text_size":          { "value": "{typography.font_size.label_large}", "type": "dimension" },
      "elevation_rest":     { "value": "{elevation.level1}", "type": "shadow" },
      "elevation_hover":    { "value": "{elevation.level2}", "type": "shadow" },
      "elevation_pressed":  { "value": "{elevation.level0}", "type": "shadow" }
    },

    "text_input": {
      "height":        { "value": "40px",          "type": "dimension" },
      "padding_h":     { "value": "{spacing.m}",   "type": "dimension" },
      "radius":        { "value": "{radius.small}", "type": "dimension" },
      "font_size":     { "value": "{typography.font_size.body_large}", "type": "dimension" },
      "border_width":  { "value": "1px",            "type": "dimension" }
    },

    "card": {
      "padding":     { "value": "{spacing.l}",    "type": "dimension" },
      "radius":      { "value": "{radius.large}", "type": "dimension" },
      "border_width": { "value": "1px",           "type": "dimension" },
      "elevation_rest":  { "value": "{elevation.level0}", "type": "shadow" },
      "elevation_hover": { "value": "{elevation.level2}", "type": "shadow" }
    },

    "modal": {
      "radius":     { "value": "{radius.large}",   "type": "dimension" },
      "shadow":     { "value": "{elevation.level3}", "type": "shadow" },
      "max_width":  { "value": "600px",            "type": "dimension" }
    },

    "badge": {
      "radius":     { "value": "{radius.full}",        "type": "dimension" },
      "font_size":  { "value": "{typography.font_size.xs}", "type": "dimension" }
    },

    "tooltip": {
      "radius":     { "value": "{radius.small}",        "type": "dimension" },
      "font_size":  { "value": "{typography.font_size.xs}", "type": "dimension" }
    },

    "progress": {
      "height": { "value": "8px", "type": "dimension" }
    },

    "tabs": {
      "indicator_height": { "value": "3px", "type": "dimension" }
    }
  }
}
