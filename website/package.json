{
  "name": "website",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "npm run pagefind:dev && docusaurus start",
    "build": "npm run build:docusaurus && npm run pagefind:index",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "build:docusaurus": "docusaurus build",
    "pagefind:index": "pagefind --site build --force-language en --exclude-selectors \"nav, footer, .theme-doc-toc-desktop, .breadcrumbs, .pagination-nav, .navbar-sidebar\" --include-characters \"_:#<>!()\"",
    "start:fast": "docusaurus start",
    "pagefind:index:static": "pagefind --site build --force-language en --exclude-selectors \"nav, footer, .theme-doc-toc-desktop, .breadcrumbs, .pagination-nav, .navbar-sidebar\" --include-characters \"_:#<>!()\" --output-path static/pagefind",
    "pagefind:dev": "npm run build:docusaurus && npm run pagefind:index:static",
    "charts:generate": "cd .. && FISSION_UPDATE_CHART_DOCS=1 cargo test -p chart-gallery --test live_e2e generate_real_chart_doc_screenshots -- --ignored --nocapture"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.1",
    "@docusaurus/faster": "3.10.1",
    "@docusaurus/preset-classic": "3.10.1",
    "@mdx-js/react": "^3.0.0",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.10.1",
    "@docusaurus/tsconfig": "3.10.1",
    "@docusaurus/types": "3.10.1",
    "@types/react": "^19.0.0",
    "pagefind": "^1.5.2",
    "typescript": "~6.0.2"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=20.0"
  }
}
